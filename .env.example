# ==============================================================================
#                      OPTIMUS ENGINE ENVIRONMENT CONFIGURATION
# ==============================================================================
# Copy this file to '.env' and fill in your custom parameters and API keys.
# Do not commit your final '.env' file containing active credentials to git.
# ==============================================================================

# ------------------------------------------------------------------------------
# SPEECH MATRIX CONFIGURATION (STT / TTS)
# ------------------------------------------------------------------------------
# Input language code for Speech-to-Text (e.g., hi-IN, en-US)
INPUT_LANGUAGE=hi-IN

# Voice model for Text-to-Speech engine (e.g., am_adam, af_bella)
ASSISTANT_VOICE=am_adam


# ------------------------------------------------------------------------------
# OFFLINE / LOCAL ENGINE SETTINGS (LM Studio, Ollama, etc.)
# ------------------------------------------------------------------------------
# Set to 'True' to bypass checking for a local server and force Cloud APIs
FORCE_ONLINE=False

# Base URL pointing to your running offline local LLM server
LOCAL_BASE_URL=http://localhost:1234/v1

# Target model identifiers loaded on your local server
LOCAL_CHAT_MODEL=local-model
LOCAL_DECISION_MODEL=local-model

# API Key for local server (defaults to 'lm-studio')
LOCAL_API_KEY=lm-studio


# ------------------------------------------------------------------------------
# CLOUD APIs CONFIGURATION (Used if FORCE_ONLINE=True or local server is down)
# ------------------------------------------------------------------------------
# Cloud API Credentials (leave blank if running purely local/offline)
CohereAPIKey=your_cohere_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here


# Cloud model identifiers
COHERE_DECISION_MODEL=command-r-plus-08-2024
GEMINI_CHAT_MODEL=gemini-2.5-flash


# ==========================================
# ASSISTANT IDENTITY PROFILE
# ==========================================
ASSISTANT_NAME=OPTIMUS
# Options: Male / Female
ASSISTANT_GENDER=Female

# Language setting for systemic injection
LANGUAGE=English
USERNAME=lucifer046

